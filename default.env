COMPOSE_FILE=hyperliquid.yml:monitoring.yml

# Hyperliquid network to join; valid values are "Mainnet" or "Testnet"
CHAIN=Mainnet
USERNAME=hyperliquid
NODE_TYPE=
VALIDATOR_PRIVATE_KEY=

# Port configuration
P2P_PORT_RANGE=4000-4010
EVM_RPC_PORT=3001

# GPG Public Key URL for verifying binaries
PUB_KEY_URL=https://raw.githubusercontent.com/hyperliquid-dex/node/refs/heads/main/pub_key.asc

# Mainnet Root Node IPs (JSON format for override_gossip_config.json) Refer here:https://github.com/hyperliquid-dex/node?tab=readme-ov-file#mainnet-non-validator-seed-peers
MAINNET_ROOT_IPS='[{"Ip": "57.182.103.24"},{"Ip": "46.105.222.166"},{"Ip": "8.211.133.129"}]'
# Optional, reference from https://hyperliquid-testnet.imperator.co/peers.json
TESTNET_ROOT_IPS='[{"Ip": "13.213.240.190"},{"Ip": "146.59.69.10"}]'

# Reserved Peer IPs (JSON array format) - IPs that can always connect to this peer
# Useful for validators to maintain reliable connections with specific peers
# Example: RESERVED_PEER_IPS='["5.6.7.8", "9.10.11.12"]'
RESERVED_PEER_IPS='[]'

# Extra command-line flags for hl-visor
EXTRA_FLAGS="--replica-cmds-style recent-actions"

# Firewall configuration for validators
# This creates ~/hl/file_mod_time_tracker/firewall_ips.json with the whitelisted validator IPs
# Set to empty array [] to create an empty firewall config
# FIREWALL_IPS='[
#  {"ip": "1.2.3.4", "name": "Example Validator 1", "allowed": true},
#  {"ip": "5.6.7.8", "name": "Example Validator 2", "allowed": true}
# ]'
FIREWALL_IPS='[]'

# Sentry node IPs.
# Maximum 2 ips.
# SENTRY_IPS='["1.2.3.4", "5.6.7.8"]'
SENTRY_IPS='[]'

# Monitoring
NODE_ALIAS=local
MONITORING_PORT=8086

# Traefik settings (used by hyperliquid.yml if ext-network.yml is included in COMPOSE_FILE)
# Domain for Traefik proxy
DOMAIN=example.com
RPC_HOST=hyperliquid
RPC_LB=hyperliquid-lb

LOG_LEVEL=info

# Slack alerts configuration
# SLACK_CHANNEL should be the channel ID (e.g., C000...)
# SLACK_KEY should be the bearer token (e.g., Bearer xoxb-...)
SLACK_CHANNEL=
SLACK_KEY=

# Validator publisher configuration.
# Use these only on a dedicated publisher host with COMPOSE_FILE=validator-publisher.yml.
VALIDATOR_PUBLISHER_CHAIN=Mainnet
VALIDATOR_PUBLISHER_USERNAME=hyperliquid
VALIDATOR_PUBLISHER_VISOR_URL=https://binaries.hyperliquid.xyz/validator-publisher/visor
VALIDATOR_PUBLISHER_RPC_ALCHEMY_URL=
VALIDATOR_PUBLISHER_RPC_QUICKNODE_URL=
VALIDATOR_PUBLISHER_RPC_INFURA_URL=
VALIDATOR_PUBLISHER_RPC_CHAINSTACK_URL=
VALIDATOR_PUBLISHER_RPC_ANKR_URL=
VALIDATOR_PUBLISHER_RPC_DRPC_URL=
VALIDATOR_PUBLISHER_RPC_SEVENTH_NAME=getblock
VALIDATOR_PUBLISHER_RPC_SEVENTH_URL=
VALIDATOR_PUBLISHER_ETHERSCAN_API_URL=https://api.etherscan.io/v2/api
VALIDATOR_PUBLISHER_ETHERSCAN_API_KEY=
VALIDATOR_PUBLISHER_BLOCKSCOUT_URL=https://arbitrum.blockscout.com/api
VALIDATOR_PUBLISHER_AGENT_KEY=
VALIDATOR_PUBLISHER_SLACK_KEY=
VALIDATOR_PUBLISHER_SLACK_ERRORS_CHANNEL=
VALIDATOR_PUBLISHER_SLACK_OUTCOME_ACTIONS_CHANNEL=
VALIDATOR_PUBLISHER_CRIT_MSG_IGNORES='[]'
VALIDATOR_PUBLISHER_FORWARD_FILE_LOGS=true
VALIDATOR_PUBLISHER_FORWARD_LOG_TAIL_LINES=20
VALIDATOR_PUBLISHER_LOG_DISCOVERY_INTERVAL=1

# AQA publisher configuration.
# Use this on a non-validator publisher host with COMPOSE_FILE=aqa-publisher.yml
# or alongside validator-publisher with COMPOSE_FILE=validator-publisher.yml:aqa-publisher.yml.
AQA_PUBLISHER_VERSION=v1.2.0
AQA_PUBLISHER_USERNAME=hyperliquid
AQA_PUBLISHER_PRIVATE_KEY=
AQA_PUBLISHER_NETWORK=mainnet
AQA_PUBLISHER_RUST_LOG=info

# Expose using traefik
DOCKER_EXT_NETWORK=traefik_default
ENV_VERSION=1
